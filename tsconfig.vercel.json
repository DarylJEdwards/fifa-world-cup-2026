{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "server/**/*.ts", "src/data/**/*.ts", "src/lib/**/*.ts", "src/types.ts"],
  "exclude": ["**/*.test.ts"]
}
